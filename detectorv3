def subdomain_scan(domain):
    import threading

    print(Fore.CYAN + "\n[+] SUBDOMAIN SCAN")

    found = set()
    lock = threading.Lock()

    # =========================
    # 1. CRT.SH
    # =========================
    print(Fore.YELLOW + "[INFO] crt.sh...")

    try:
        url = f"https://crt.sh/?q=%25.{domain}&output=json"
        r = requests.get(url, timeout=10)

        if r.status_code == 200:
            data = r.json()

            for entry in data:
                names = entry.get("name_value", "").split("\n")

                for sub in names:
                    sub = sub.strip().lower().replace("*.", "")

                    if domain in sub:
                        with lock:
                            if sub not in found:
                                print(Fore.GREEN + f"[CRT] {sub}")
                                found.add(sub)
    except:
        pass

    # =========================
    # 2. HACKERTARGET
    # =========================
    print(Fore.YELLOW + "[INFO] hackertarget...")

    try:
        url = f"https://api.hackertarget.com/hostsearch/?q={domain}"
        r = requests.get(url, timeout=10)

        for line in r.text.splitlines():
            sub = line.split(",")[0]

            if domain in sub:
                with lock:
                    if sub not in found:
                        print(Fore.GREEN + f"[API] {sub}")
                        found.add(sub)
    except:
        pass

    # =========================
    # 3. RAPIDDNS
    # =========================
    print(Fore.YELLOW + "[INFO] rapiddns...")

    try:
        url = f"https://rapiddns.io/subdomain/{domain}?full=1"
        r = requests.get(url, timeout=10)

        subs = re.findall(rf'>([a-zA-Z0-9_\-\.]+\.{domain})<', r.text)

        for sub in subs:
            with lock:
                if sub not in found:
                    print(Fore.GREEN + f"[RAPID] {sub}")
                    found.add(sub)
    except:
        pass

    # =========================
    # 4. THREATCROWD
    # =========================
    print(Fore.YELLOW + "[INFO] threatcrowd...")

    try:
        url = f"https://www.threatcrowd.org/searchApi/v2/domain/report/?domain={domain}"
        r = requests.get(url, timeout=10).json()

        for sub in r.get("subdomains", []):
            with lock:
                if sub not in found:
                    print(Fore.GREEN + f"[TC] {sub}")
                    found.add(sub)
    except:
        pass

    # =========================
    # 5. BRUTEFORCE
    # =========================
    print(Fore.YELLOW + "[INFO] bruteforce...")

    subs = [
        "www","mail","ftp","webmail","admin","test","dev","api",
        "beta","staging","portal","vpn","cpanel","whm","ns1","ns2",
        "blog","shop","support","secure","gateway","m","mobile",
        "app","cdn","static","img","assets","data","db","backup",
        "old","new","demo","internal","intranet","auth","sso"
    ]

    def scan(sub):
        if STOP_FLAG:
            return

        try:
            full = f"{sub}.{domain}"
            socket.gethostbyname(full)

            with lock:
                if full not in found:
                    print(Fore.GREEN + f"[BRUTE] {full}")
                    found.add(full)

        except:
            pass

    threads = []

    for s in subs:
        if STOP_FLAG:
            break

        t = threading.Thread(target=scan, args=(s,))
        t.start()
        threads.append(t)

    for t in threads:
        t.join()

    # =========================
    # FINAL RESULT
    # =========================
    print(Fore.CYAN + "\n[+] FINAL RESULT")
    print(Fore.GREEN + f"Total unik ditemukan: {len(found)}")

# =========================
# DIRECTORY SCAN
# =========================
def dir_scan(domain):
    import asyncio
    import aiohttp
    import random

    print(Fore.CYAN + "\n[+] DIRSCAN ASYNC")

    base_url = get_base_url(domain)

    USER_AGENTS = [
        "Mozilla/5.0",
        "Chrome/120.0",
        "Safari/537.36",
        "Firefox/115.0"
    ]

    def rand_headers():
        return {
            "User-Agent": random.choice(USER_AGENTS),
            "Accept": "text/html"
        }

    # =========================
    # WORDLIST
    # =========================
    try:
        with open("/usr/share/seclists/Discovery/Web-Content/common.txt") as f:
            words = [x.strip() for x in f.readlines()]
        print(Fore.GREEN + f"[INFO] Wordlist: {len(words)}")
    except:
        words = ["admin","login","dashboard","api","backup"]

    exts = ["", ".php", ".bak", ".zip", ".txt"]

    # =========================
    # ASYNC SCAN
    # =========================
    async def scan(session, path, base_size):
        if STOP_FLAG:
            return

        url = f"{base_url}/{path}"

        try:
            async with session.get(url, headers=rand_headers(), timeout=5) as r:
                text = await r.text()
                size = len(text)

                if abs(size - base_size) < 20:
                    return

                if STOP_FLAG:
                    return

                if r.status == 200:
                    print(Fore.GREEN + f"[200] {url} [{size}]")
                elif r.status in [301,302]:
                    print(Fore.YELLOW + f"[REDIRECT] {url}")
                elif r.status == 403:
                    print(Fore.MAGENTA + f"[403] {url}")
                else:
                    print(Fore.WHITE + f"[{r.status}] {url}")

        except:
            pass

    async def main():
        timeout = aiohttp.ClientTimeout(total=5)

        async with aiohttp.ClientSession(timeout=timeout) as session:

            # baseline
            try:
                async with session.get(base_url, headers=rand_headers()) as r:
                    base_text = await r.text()
                    base_size = len(base_text)
                    print(Fore.YELLOW + f"[BASELINE] {base_size}")
            except:
                base_size = 0

            tasks = []

            for w in words:
                if STOP_FLAG:
                    break

                for e in exts:
                    path = w + e
                    tasks.append(scan(session, path, base_size))

            # jalankan async batch
            try:
                await asyncio.gather(*tasks)
            except asyncio.CancelledError:
                pass

    # =========================
    # RUN LOOP
    # =========================
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        global STOP_FLAG
        STOP_FLAG = True
        print(Fore.RED + "\n[!] Scan stopped instantly")

    print(Fore.CYAN + "\n[+] DONE")

