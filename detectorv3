def web_fingerprint(domain):
    print(Fore.CYAN + "\n[+] WEB FINGERPRINT (ADVANCED)")

    try:
        r = requests.get(f"http://{domain}", timeout=5)
        html = r.text.lower()

        # ================= BASIC =================
        title = re.findall(r"<title>(.*?)</title>", html)
        if title:
            print(Fore.GREEN + f"[TITLE] {title[0]}")

        print(Fore.YELLOW + f"[SIZE] {len(r.text)} bytes")

        # ================= SERVER =================
        server = r.headers.get("Server", "")
        if server:
            print(Fore.WHITE + f"[SERVER] {server}")

        # ================= CMS DETECTION =================
        if "wp-content" in html or "wp-includes" in html:
            print(Fore.MAGENTA + "[CMS] WordPress")

        # ================= FRAMEWORK =================
        cookies = str(r.cookies).lower()

        if "laravel" in cookies or "xsrf-token" in cookies:
            print(Fore.MAGENTA + "[FRAMEWORK] Laravel")

        if "php" in server.lower():
            print(Fore.MAGENTA + "[LANGUAGE] PHP")

        # ================= SECURITY HEADERS =================
        print(Fore.CYAN + "\n[+] SECURITY HEADERS")

        sec_headers = [
            "x-frame-options",
            "x-xss-protection",
            "x-content-type-options",
            "strict-transport-security",
            "content-security-policy"
        ]

        for h in sec_headers:
            if h in r.headers:
                print(Fore.GREEN + f"[FOUND] {h}: {r.headers[h]}")
            else:
                print(Fore.RED + f"[MISSING] {h}")

        # ================= CDN DETECTION =================
        if "cloudflare" in server.lower():
            print(Fore.YELLOW + "\n[WARNING] Cloudflare detected")

    except Exception as e:
        print(Fore.RED + f"[-] Error: {e}")

