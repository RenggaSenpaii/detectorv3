def endpoint_analysis(domain):
    import requests
    import re

    global crawler_results

    print(Fore.CYAN + "\n[+] ENDPOINT ANALYSIS")

    headers = {
        "User-Agent": "Mozilla/5.0"
    }

    if not crawler_results:
        print(Fore.YELLOW + "[INFO] Tidak ada data crawler → jalankan crawler dulu")
        return

    for url in crawler_results:

        try:
            r = requests.get(url, headers=headers, timeout=5, allow_redirects=True)
            html = r.text.lower()
            size = len(r.text)

            # ambil title
            title = ""
            t = re.findall(r"<title>(.*?)</title>", html)
            if t:
                title = t[0]

            label = []

            # =========================
            # DETECTION LOGIC
            # =========================

            # LOGIN DETECT
            if any(x in url for x in ["login", "signin", "auth"]):
                label.append("LOGIN")

            if "password" in html:
                label.append("LOGIN_FORM")

            # API DETECT
            if "api" in url or "json" in html:
                label.append("API")

            # INTERESTING PATH
            if any(x in url for x in [
                "admin","dashboard","panel","cpanel",
                "upload","file","config","backup"
            ]):
                label.append("INTERESTING")

            # =========================
            # OUTPUT
            # =========================
            if label:
                print(
                    Fore.GREEN + f"[{','.join(label)}] " +
                    Fore.WHITE + f"{url} " +
                    Fore.YELLOW + f"({r.status_code}) [{size}] " +
                    Fore.CYAN + f"{title}"
                )
            else:
                print(
                    Fore.WHITE + f"[NORMAL] {url} ({r.status_code})"
                )

        except:
            pass

    print(Fore.CYAN + "\n[+] DONE")

