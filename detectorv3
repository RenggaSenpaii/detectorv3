def valid_domain(domain):
    import re

    # hanya huruf, angka, titik, dash
    pattern = r"^[a-zA-Z0-9.-]+$"

    if not re.match(pattern, domain):
        return False

    # minimal ada titik (domain.com)
    if "." not in domain:
        return False

    return True


def get_base_url(domain):
    import requests

    try:
        r = requests.get(f"https://{domain}", timeout=5, allow_redirects=True)
        return r.url.rstrip("/")
    except:
        return f"http://{domain}"

