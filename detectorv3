# CRAWLER
# =========================
def crawler(domain):
    import requests
    import re
    from urllib.parse import urljoin, urlparse

    global crawler_results, STOP_FLAG
    STOP_FLAG = False
    crawler_results = []

    print(Fore.CYAN + "\n[+] CRAWLER")

    headers = {
        "User-Agent": "Mozilla/5.0"
    }

    visited = set()
    js_files = set()

    base = get_base_url(domain)

    base_urls = [base]

    def fetch(url):
        try:
            r = requests.get(url, headers=headers, timeout=5, allow_redirects=True)
            return r.text
        except:
            return ""    

    # =========================
    # STEP 1: HTML CRAWL
    # =========================
    for b in base_urls:
        html = fetch(b)
        if STOP_FLAG:
            break

        print(Fore.YELLOW + f"[VISIT] {b}")

        # ambil href
        links = re.findall(r'href=["\'](.*?)["\']', html)

        # ambil JS file
        scripts = re.findall(r'src=["\'](.*?\.js[^"\']*)["\']', html)

        for link in links:
            full = urljoin(b, link)

             # FILTER STATIC FILE
            if any(full.lower().endswith(ext) for ext in [".png",".jpg",".jpeg",".css",".js",".woff",".svg",".ico"]):
                continue

            if domain in full:
                full = full.split("#")[0]

                if full not in crawler_results:
                    print(Fore.GREEN + f"[URL] {full}")
                    crawler_results.append(full)

        for js in scripts:
            full = urljoin(b, js)
            if domain in full:
                print(Fore.MAGENTA + f"[JS] {full}")
                js_files.add(full)

    # =========================
    # STEP 2: JS PARSE
    # =========================
    print(Fore.CYAN + "\n[+] JS ANALYSIS")

    param_urls = set()

    for js in js_files:
        if STOP_FLAG:
            break

        print(Fore.YELLOW + f"[FETCH JS] {js}")

        content = fetch(js)

        # pastikan content ada
        if not content:
            continue

        # =========================
        # ENDPOINT
        # =========================
        endpoints = re.findall(r'["\'](/[^"\']+)["\']', content)

        for ep in endpoints:
            full = f"{base.rstrip('/')}{ep}"

            if ep.strip() in ["//", "/", ""]:
                continue

            if any(x in ep for x in [",", ">", "<", "(", ")", " "]):
                continue

            if len(ep.strip()) < 2:
                continue

            if len(ep) < 4:
                continue

            if domain in full and full not in crawler_results:
                print(Fore.GREEN + f"[JS-ENDPOINT] {full}")
                crawler_results.append(full)

        # =========================
        # PARAM FULL
        # =========================
        matches = re.findall(r'["\'](/[^"\']*\?[^\s"\']+)["\']', content)

        for m in matches:
            full = f"{base.rstrip('/')}{m}"

            if domain in full:
                print(Fore.GREEN + f"[JS-PARAM] {full}")
                crawler_results.append(full)
                param_urls.add(full)

        # =========================
        # PARAM GUESS (FILTERED)
        # =========================
        params = re.findall(r'([a-zA-Z0-9_]{3,})=', content)

        blacklist = list(set([
            "function","return","var","let","const",
            "true","false","null","undefined",
            "class","style","width","height",
            "color","background","transition",
            "index","constructor","prototype",
            "jquery","guid","data","queue","hidden",
            "minwidth","maxwidth","sliding","slide",
            "scrollbar","scrollbarwidth",
            "pagex","pagey",
            "unique","uniquesort","tokenize",
            "acceptdata","getbyid","getuid","qsa"
        ]))    

        for p in params:
            if p.lower() in blacklist:
                continue

            if len(p) < 4:
                continue

            if any(x in p.lower() for x in ["id","user","token","search","q","page","data","api"]):
                guess = f"{base}/?{p}="
                
                if guess not in param_urls:
                    print(Fore.YELLOW + f"[VALID-PARAM] {guess}")
                    param_urls.add(guess)
    
    # =========================
    # STEP 3: PARAM REPORT
    # =========================
    print(Fore.CYAN + "\n[+] PARAM URL FOUND")

    for u in param_urls:
        print(Fore.RED + f"[PARAM] {u}")

    # =========================
    # FALLBACK (kalau kosong)
    # =========================
    if len(crawler_results) == 0:
        print(Fore.YELLOW + "[INFO] fallback aktif")

        fallback = [
            "/login","/dashboard","/api",
            "/admin","/user","/search"
        ]

        for f in fallback:
            url = f"{base}{f}"
            print(Fore.GREEN + f"[GUESS] {url}")
            crawler_results.append(url)

    print(Fore.CYAN + "\n[+] FINAL SUMMARY")

    print(Fore.GREEN + f"[ENDPOINT] {len(crawler_results)}")
    print(Fore.YELLOW + f"[PARAM] {len(param_urls)}")
    print(Fore.MAGENTA + f"[JS FILE] {len(js_files)}")  

