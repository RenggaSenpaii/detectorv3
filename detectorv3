# =========================
def port_scan(domain):
    import threading

    print(Fore.CYAN + "\n[+] ADVANCED PORT SCAN (NMAP STYLE)")

    ports = [
        21,22,23,25,53,
        80,110,139,143,
        443,445,465,587,
        993,995,1433,1521,
        2082,2083,2086,2087,
        2095,2096,2181,3000,
        3306,3389,4444,5000,
        5432,5601,5900,6379,
        7001,8000,8008,8080,
        8081,8443,8888,9000,
        9090,9200,9999
    ]

    services = {
        21: "FTP",
        22: "SSH",
        23: "TELNET",
        25: "SMTP",
        53: "DNS",
        80: "HTTP",
        110: "POP3",
        139: "NETBIOS",
        143: "IMAP",
        443: "HTTPS",
        445: "SMB",
        465: "SMTPS",
        587: "SMTP",
        993: "IMAPS",
        995: "POP3S",
        1433: "MSSQL",
        1521: "ORACLE",
        3306: "MYSQL",
        3389: "RDP",
        5432: "POSTGRES",
        6379: "REDIS",
        8080: "HTTP-ALT",
        8443: "HTTPS-ALT"
    }

    try:
        ip = socket.gethostbyname(domain)
    except:
        print(Fore.RED + "[-] Gagal resolve IP")
        return

    open_ports = []
    lock = threading.Lock()

    def scan(port):
        if STOP_FLAG:
            return

        try:
            s = socket.socket()
            s.settimeout(1)

            if s.connect_ex((ip, port)) == 0:
                service = services.get(port, "UNKNOWN")

                banner = ""
                try:
                    s.send(b"HEAD / HTTP/1.0\r\n\r\n")
                    banner = s.recv(100).decode(errors="ignore").strip()
                except:
                    pass

                with lock:
                    print(
                        Fore.GREEN + f"[OPEN] Port {port} " +
                        Fore.YELLOW + f"({service})"
                    )

                    if banner:
                        print(Fore.MAGENTA + f"   └─ Banner: {banner[:80]}")

                    open_ports.append(port)

            s.close()

        except:
            pass

    threads = []

    for port in ports:
        t = threading.Thread(target=scan, args=(port,))
        t.start()
        threads.append(t)

    for t in threads:
        t.join()

    print(Fore.CYAN + "\n[+] SUMMARY")
    print(Fore.GREEN + f"Open ports: {len(open_ports)}")

    if open_ports:
        print(Fore.YELLOW + f"Ports: {', '.join(map(str, open_ports))}")

